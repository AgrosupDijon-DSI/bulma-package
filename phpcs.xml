<?xml version="1.0"?>
<ruleset name="Custom Standard" namespace="IAD\CS\Standard">
    <!-- See https://github.com/squizlabs/PHP_CodeSniffer/wiki/Annotated-ruleset for information -->
    <description>IAD Coding standard</description>

    <file>.</file>

    <config name="testVersion" value="8.2-"/>

    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern type="relative">^.tools/*</exclude-pattern>
    <exclude-pattern type="relative">^vendor/*</exclude-pattern>
    <exclude-pattern type="relative">^public/*</exclude-pattern>

    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="PHPCompatibility"/>

    <rule ref="PSR12">
        <exclude name="Generic.Files.LineLength.TooLong"/>
        <exclude name="Squiz.WhiteSpace.ScopeClosingBrace.ContentBefore"/>
        <exclude-pattern>*Resources/Private/Contrib/Php/*</exclude-pattern>
    </rule>

    <rule ref="PHPCompatibility.FunctionUse.NewFunctions.fpowFound">
        <exclude-pattern>*Resources/Private/Contrib/Php/vendor/scssphp/scssphp/src/Util/NumberUtil.php</exclude-pattern>
    </rule>

</ruleset>
